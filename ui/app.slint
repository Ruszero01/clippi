import { ListView } from "std-widgets.slint";
import { SettingsPanel } from "SettingsPanel.slint";

export struct ClipboardEntry {
    id: int,
    preview: string,
    content-type: string,
    time-label: string,
}

export component App inherits Window {
    title: "Clippi";
    preferred-width: 320px;
    preferred-height: 480px;
    no-frame: true;
    always-on-top: true;
    background: transparent;

    // 窗口最小尺寸
    min-width: 320px;
    min-height: 480px;

    in property <[ClipboardEntry]> clipboard-items: [];
    in property <int> item-count: 0;
    in-out property <bool> dark-mode: false;

    // 视图切换
    in-out property <string> current-view: "clipboard";
    in-out property <bool> auto-start: false;
    in-out property <string> db-path: "";
    in-out property <string> settings-error: "";
    in-out property <int> active-tab: 0;

    // 双击检测
    in-out property <int> last-clicked-id: -1;
    in-out property <bool> click-pending: false;

    callback copy-item(int);
    callback paste-item(int);
    callback clear-all();
    callback move-window(float, float);
    callback close-window();
    callback toggle-auto-start();
    callback pick-db-path();
    callback resize-window(float, float);

    // ========== 主题色板 ==========
    property <color> bg:            dark-mode ? #0e1018 : #f2f3f8;
    property <color> surface:       dark-mode ? #181a26 : #ffffff;
    property <color> surface-hover: dark-mode ? #22243a : #f4f5fb;
    property <color> surface-press: dark-mode ? #2c2e4a : #ebedf5;
    property <color> text-1:        dark-mode ? #e6e9f2 : #1a1c2e;
    property <color> text-2:        dark-mode ? #8a8ea8 : #7c809a;
    property <color> text-3:        dark-mode ? #555874 : #b4b9ca;
    property <color> accent:        dark-mode ? #8b8eff : #5f5ff0;
    property <color> accent-soft:   dark-mode ? #222440 : #eeeefd;
    property <color> divider:       dark-mode ? #262840 : #e6e8f0;
    property <color> titlebar-bg:   dark-mode ? #12131c : #ffffff;
    property <color> btn-hover:     dark-mode ? #262840 : #f0f1f8;
    property <color> danger:        #ff5f57;

    // 双击检测定时器
    double-click-timer := Timer {
        interval: 300ms;
        running: root.click-pending;
        triggered => {
            root.click-pending = false;
            if (root.last-clicked-id >= 0) {
                root.copy-item(root.last-clicked-id);
                root.last-clicked-id = -1;
            }
        }
    }

    Rectangle {
        border-radius: 12px;
        background: bg;
        clip: true;

        // ========== 缩放手柄 ==========
        // 右边缘
        resize-right := TouchArea {
            x: parent.width - 6px;
            y: 12px;
            width: 6px;
            height: parent.height - 24px;
            mouse-cursor: col-resize;

            moved => {
                if (self.pressed) {
                    root.resize-window((self.mouse-x - self.pressed-x) / 1px, 0);
                }
            }
        }

        // 底边缘
        resize-bottom := TouchArea {
            x: 12px;
            y: parent.height - 6px;
            width: parent.width - 24px;
            height: 6px;
            mouse-cursor: row-resize;

            moved => {
                if (self.pressed) {
                    root.resize-window(0, (self.mouse-y - self.pressed-y) / 1px);
                }
            }
        }

        // 右下角
        resize-corner := TouchArea {
            x: parent.width - 12px;
            y: parent.height - 12px;
            width: 12px;
            height: 12px;
            mouse-cursor: col-resize;

            moved => {
                if (self.pressed) {
                    root.resize-window((self.mouse-x - self.pressed-x) / 1px, (self.mouse-y - self.pressed-y) / 1px);
                }
            }
        }

        VerticalLayout {
            spacing: 0px;

            // ========== 标题栏 ==========
        Rectangle {
            height: 38px;
            background: bg;

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 4px;
                alignment: space-between;

                // 应用名称
                HorizontalLayout {
                    spacing: 7px;
                    alignment: center;

                    Rectangle {
                        width: 7px;
                        height: 7px;
                        border-radius: 4px;
                        background: accent;
                    }

                    Text {
                        text: "Clippi";
                        font-size: 13px;
                        font-weight: 700;
                        color: text-1;
                        vertical-alignment: center;
                    }
                }

                // 右侧按钮组
                HorizontalLayout {
                    spacing: 2px;
                    alignment: center;

                    // 设置按钮
                    Rectangle {
                        width: 28px;
                        height: 28px;
                        border-radius: 7px;
                        background: settings-ta.has-hover ? btn-hover : transparent;

                        settings-ta := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => {
                                root.current-view = "settings";
                            }
                        }

                        Text {
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            text: "G";
                            font-size: 10px;
                            font-weight: 700;
                            color: text-2;
                        }
                    }

                    // 主题切换
                    Rectangle {
                        width: 28px;
                        height: 28px;
                        border-radius: 7px;
                        background: theme-ta.has-hover ? btn-hover : transparent;

                        theme-ta := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => {
                                root.dark-mode = !root.dark-mode;
                            }
                        }

                        Text {
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            text: dark-mode ? "S" : "M";
                            font-size: 10px;
                            font-weight: 700;
                            color: text-2;
                        }
                    }

                    // 关闭按钮
                    Rectangle {
                        width: 28px;
                        height: 28px;
                        border-radius: 7px;
                        background: close-ta.has-hover ? danger : transparent;

                        close-ta := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => {
                                root.close-window();
                            }
                        }

                        Text {
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            text: "X";
                            font-size: 10px;
                            font-weight: 600;
                            color: close-ta.has-hover ? #ffffff : text-2;
                        }
                    }
                }
            }

            // 拖动区域
            drag-ta := TouchArea {
                x: 0px;
                y: 0px;
                width: parent.width - 92px;
                height: parent.height;
                mouse-cursor: grab;

                moved => {
                    if (self.pressed) {
                        root.move-window((self.mouse-x - self.pressed-x) / 1px, (self.mouse-y - self.pressed-y) / 1px);
                    }
                }
            }
        }

        // ========== 列表区域 ==========
        if root.current-view == "clipboard": VerticalLayout {
            padding-top: 4px;
            padding-left: 8px;
            padding-right: 8px;
            padding-bottom: 8px;
            spacing: 4px;

            // 空状态
            if root.item-count == 0: VerticalLayout {
                alignment: center;
                height: 200px;
                spacing: 6px;

                Text {
                    text: "暂无剪贴板内容";
                    font-size: 13px;
                    color: text-2;
                    horizontal-alignment: center;
                }

                Text {
                    text: "复制文本后将自动显示在这里";
                    font-size: 11px;
                    color: text-3;
                    horizontal-alignment: center;
                }
            }

            // 剪贴板列表
            ListView {
                for entry in root.clipboard-items: Rectangle {
                    height: 52px;
                    border-radius: 10px;
                    background: item-ta.pressed ? surface-press : item-ta.has-hover ? surface-hover : surface;
                    border-width: 1px;
                    border-color: divider;

                    item-ta := TouchArea {
                        width: parent.width - 32px;
                        height: parent.height;
                        clicked => {
                            if (root.click-pending && root.last-clicked-id == entry.id) {
                                root.click-pending = false;
                                root.last-clicked-id = -1;
                                root.paste-item(entry.id);
                            } else {
                                root.last-clicked-id = entry.id;
                                root.click-pending = true;
                            }
                        }
                    }

                    HorizontalLayout {
                        padding: 6px;
                        padding-left: 10px;
                        spacing: 8px;

                        // 类型图标
                        Rectangle {
                            width: 34px;
                            height: 34px;
                            border-radius: 9px;
                            background: accent-soft;

                            Text {
                                x: (parent.width - self.width) / 2;
                                y: (parent.height - self.height) / 2;
                                text: entry.content-type == "text" ? "T" : entry.content-type == "html" ? "H" : "I";
                                font-size: 13px;
                                font-weight: 700;
                                color: accent;
                            }
                        }

                        VerticalLayout {
                            spacing: 2px;

                            Text {
                                text: entry.preview;
                                font-size: 12px;
                                color: text-1;
                                overflow: elide;
                                horizontal-alignment: left;
                                vertical-alignment: center;
                            }

                            Text {
                                text: entry.time-label;
                                font-size: 10px;
                                color: text-3;
                                horizontal-alignment: left;
                                vertical-alignment: center;
                            }
                        }

                        // 复制按钮
                        Rectangle {
                            width: 28px;
                            height: 28px;
                            border-radius: 7px;
                            background: copy-ta.has-hover ? btn-hover : transparent;

                            copy-ta := TouchArea {
                                width: parent.width;
                                height: parent.height;
                                clicked => {
                                    root.click-pending = false;
                                    root.last-clicked-id = -1;
                                    root.copy-item(entry.id);
                                }
                            }

                            Text {
                                x: (parent.width - self.width) / 2;
                                y: (parent.height - self.height) / 2;
                                text: "C";
                                font-size: 11px;
                                font-weight: 700;
                                color: copy-ta.has-hover ? accent : text-3;
                            }
                        }
                    }
                }
            }
        }

        // ========== 设置页面 ==========
        if root.current-view == "settings": SettingsPanel {
            dark-mode: root.dark-mode;
            auto-start: root.auto-start;
            db-path: root.db-path;
            settings-error: root.settings-error;
            active-tab: root.active-tab;

            back => { root.current-view = "clipboard"; }
            toggle-auto-start => { root.toggle-auto-start(); }
            pick-db-path => { root.pick-db-path(); }
        }
        }
    }
}
