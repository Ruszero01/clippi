import { ClipboardEntry } from "types.slint";
import { ClipboardList } from "ClipboardList.slint";
import { SettingsPanel } from "SettingsPanel.slint";

export component App inherits Window {
    icon: @image-url("../assets/LOGO.ico");
    title: "Clippi";
    preferred-width: 320px;
    preferred-height: 480px;
    no-frame: true;
    always-on-top: true;
    background: transparent;

    // 窗口最小尺寸
    min-width: 320px;
    min-height: 480px;

    in property <[ClipboardEntry]> clipboard-items: [];
    in property <int> item-count: 0;
    in-out property <bool> dark-mode: false;
    in-out property <int> theme-mode: 0;  // 0=system, 1=dark, 2=light

    // 视图切换
    in-out property <string> current-view: "clipboard";
    in-out property <bool> auto-start: false;
    in-out property <bool> auto-hide: false;
    in-out property <bool> pinned: false;
    in-out property <string> db-path: "";
    in-out property <string> settings-error: "";
    in-out property <int> active-tab: 0;
    in-out property <string> hotkey-display: "";
    in-out property <bool> recording-hotkey: false;

    // 双击检测
    in-out property <int> last-clicked-id: -1;
    in-out property <bool> click-pending: false;

    callback copy-item(int);
    callback paste-item(int);
    callback clear-all();
    callback move-window(float, float);
    callback close-window();
    callback toggle-auto-start();
    callback toggle-auto-hide();
    callback toggle-pinned();
    callback pick-db-path();
    callback reset-db-path();
    callback resize-window(float, float);
    callback set-hotkey(string);
    callback start-recording-hotkey();
    callback set-theme(int);

    // ========== 主题色板 ==========
    property <color> bg:            dark-mode ? #0e1018 : #f2f3f8;
    property <color> surface:       dark-mode ? #181a26 : #ffffff;
    property <color> surface-hover: dark-mode ? #22243a : #f4f5fb;
    property <color> surface-press: dark-mode ? #2c2e4a : #ebedf5;
    property <color> text-1:        dark-mode ? #e6e9f2 : #1a1c2e;
    property <color> text-2:        dark-mode ? #8a8ea8 : #7c809a;
    property <color> text-3:        dark-mode ? #555874 : #b4b9ca;
    property <color> accent:        dark-mode ? #7ecba3 : #6ab890;
    property <color> accent-soft:   dark-mode ? #1a2e24 : #e8f5ee;
    property <color> divider:       dark-mode ? #262840 : #e6e8f0;
    property <color> titlebar-bg:   dark-mode ? #12131c : #ffffff;
    property <color> btn-hover:     dark-mode ? #262840 : #f0f1f8;
    property <color> danger:        #ff5f57;

    // 双击检测定时器
    double-click-timer := Timer {
        interval: 300ms;
        running: root.click-pending;
        triggered => {
            root.click-pending = false;
            if (root.last-clicked-id >= 0) {
                root.copy-item(root.last-clicked-id);
                root.last-clicked-id = -1;
            }
        }
    }

    Rectangle {
        border-radius: 12px;
        background: bg;
        clip: true;

        // ========== 缩放手柄 ==========
        // 右边缘
        resize-right := TouchArea {
            x: parent.width - 6px;
            y: 12px;
            width: 6px;
            height: parent.height - 24px;
            mouse-cursor: col-resize;

            moved => {
                if (self.pressed) {
                    root.resize-window((self.mouse-x - self.pressed-x) / 1px, 0);
                }
            }
        }

        // 底边缘
        resize-bottom := TouchArea {
            x: 12px;
            y: parent.height - 6px;
            width: parent.width - 24px;
            height: 6px;
            mouse-cursor: row-resize;

            moved => {
                if (self.pressed) {
                    root.resize-window(0, (self.mouse-y - self.pressed-y) / 1px);
                }
            }
        }

        // 右下角
        resize-corner := TouchArea {
            x: parent.width - 12px;
            y: parent.height - 12px;
            width: 12px;
            height: 12px;
            mouse-cursor: col-resize;

            moved => {
                if (self.pressed) {
                    root.resize-window((self.mouse-x - self.pressed-x) / 1px, (self.mouse-y - self.pressed-y) / 1px);
                }
            }
        }

        VerticalLayout {
            spacing: 0px;

            // ========== 标题栏 ==========
            Rectangle {
                height: 38px;
                background: bg;

                HorizontalLayout {
                    padding-left: 12px;
                    padding-right: 4px;
                    alignment: LayoutAlignment.space-between;

                    // 应用名称 + LOGO
                    HorizontalLayout {
                        spacing: 7px;
                        VerticalLayout {
                            alignment: center;

                            Rectangle {
                                width: 20px;
                                height: 20px;

                                Image {
                                    width: 20px;
                                    height: 20px;
                                    source: @image-url("../assets/LOGO_notext.ico");
                                }
                            }
                        }

                        Text {
                            text: "Clippi";
                            font-size: 12px;
                            font-weight: 700;
                            color: text-2;
                            vertical-alignment: center;
                        }
                    }

                    // 右侧按钮组
                    HorizontalLayout {
                        spacing: 2px;
                        alignment: center;

                        // 固定按钮（免打扰模式）
                        Rectangle {
                            width: 28px;
                            height: 28px;

                            pin-ta := TouchArea {
                                width: parent.width;
                                height: parent.height;
                                clicked => { root.toggle-pinned(); }
                            }

                            Text {
                                x: (parent.width - self.width) / 2;
                                y: (parent.height - self.height) / 2;
                                text: "\u{e9ba}";
                                font-family: "iconfont";
                                font-size: 15px;
                                color: pinned ? accent : (pin-ta.has-hover ? accent : text-2);
                                transform-rotation: pinned ? 45deg : 0deg;
                                animate transform-rotation { duration: 200ms; easing: ease-out; }
                            }
                        }

                        // 设置按钮
                        Rectangle {
                            width: 28px;
                            height: 28px;

                            settings-ta := TouchArea {
                                width: parent.width;
                                height: parent.height;
                                clicked => {
                                    root.current-view = "settings";
                                }
                            }

                            Text {
                                x: (parent.width - self.width) / 2;
                                y: (parent.height - self.height) / 2;
                                text: "\u{e6b6}";
                                font-family: "iconfont";
                                font-size: 16px;
                                color: settings-ta.has-hover ? accent : text-2;
                            }
                        }

                        // 关闭按钮
                        Rectangle {
                            width: 28px;
                            height: 28px;

                            close-ta := TouchArea {
                                width: parent.width;
                                height: parent.height;
                                clicked => {
                                    root.close-window();
                                }
                            }

                            Text {
                                x: (parent.width - self.width) / 2;
                                y: (parent.height - self.height) / 2;
                                text: "\u{e676}";
                                font-family: "iconfont";
                                font-size: 15px;
                                color: close-ta.has-hover ? danger : text-2;
                            }
                        }
                    }
                }

                // 拖动区域
                drag-ta := TouchArea {
                    x: 0px;
                    y: 0px;
                    width: parent.width - 92px;
                    height: parent.height;
                    mouse-cursor: grab;

                    moved => {
                        if (self.pressed) {
                            root.move-window((self.mouse-x - self.pressed-x) / 1px, (self.mouse-y - self.pressed-y) / 1px);
                        }
                    }
                }
            }

            // ========== 内容区域 ==========
            Rectangle {
                // 两个视图重叠放置，通过 opacity 切换
                ClipboardList {
                    visible: root.current-view == "clipboard";
                    opacity: root.current-view == "clipboard" ? 1 : 0;
                    x: root.current-view == "clipboard" ? 0 : -20px;
                    animate opacity { duration: 200ms; easing: ease-out; }
                    animate x { duration: 200ms; easing: ease-out; }

                    dark-mode: root.dark-mode;
                    items: root.clipboard-items;
                    item-count: root.item-count;
                    last-clicked-id: root.last-clicked-id;
                    click-pending: root.click-pending;
                    copy-item(id) => { root.copy-item(id); }
                    paste-item(id) => { root.paste-item(id); }
                }

                SettingsPanel {
                    visible: root.current-view == "settings";
                    opacity: root.current-view == "settings" ? 1 : 0;
                    x: root.current-view == "settings" ? 0 : 20px;
                    animate opacity { duration: 200ms; easing: ease-out; }
                    animate x { duration: 200ms; easing: ease-out; }

                    dark-mode: root.dark-mode;
                    theme-mode: root.theme-mode;
                    auto-start: root.auto-start;
                    auto-hide: root.auto-hide;
                    db-path: root.db-path;
                    settings-error: root.settings-error;
                    active-tab: root.active-tab;
                    hotkey-display: root.hotkey-display;
                    recording-hotkey: root.recording-hotkey;

                    back => { root.current-view = "clipboard"; }
                    toggle-auto-start => { root.toggle-auto-start(); }
                    toggle-auto-hide => { root.toggle-auto-hide(); }
                    pick-db-path => { root.pick-db-path(); }
                    reset-db-path => { root.reset-db-path(); }
                    set-hotkey(s) => { root.set-hotkey(s); }
                    start-recording-hotkey => { root.start-recording-hotkey(); }
                    set-theme(mode) => { root.set-theme(mode); }
                }
            }
        }
    }
}
