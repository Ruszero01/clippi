import { ListView } from "std-widgets.slint";
import { ClipboardEntry } from "types.slint";

export component ClipboardList inherits Rectangle {
    // ========== 输入属性 ==========
    in property <bool> dark-mode: false;
    in property <[ClipboardEntry]> items: [];
    in property <int> item-count: 0;

    // ========== 双击检测 ==========
    in-out property <int> last-clicked-id: -1;
    in-out property <bool> click-pending: false;

    // ========== 回调 ==========
    callback copy-item(int);
    callback paste-item(int);

    // ========== 主题色板 ==========
    property <color> surface:       dark-mode ? #181a26 : #ffffff;
    property <color> surface-hover: dark-mode ? #22243a : #f4f5fb;
    property <color> surface-press: dark-mode ? #2c2e4a : #ebedf5;
    property <color> text-1:        dark-mode ? #e6e9f2 : #1a1c2e;
    property <color> text-2:        dark-mode ? #8a8ea8 : #7c809a;
    property <color> text-3:        dark-mode ? #555874 : #b4b9ca;
    property <color> accent:        dark-mode ? #7ecba3 : #6ab890;
    property <color> accent-soft:   dark-mode ? #1a2e24 : #e8f5ee;
    property <color> divider:       dark-mode ? #262840 : #e6e8f0;
    property <color> btn-hover:     dark-mode ? #262840 : #f0f1f8;

    background: transparent;

    VerticalLayout {
        padding-top: 4px;
        padding-left: 8px;
        padding-right: 8px;
        padding-bottom: 8px;
        spacing: 4px;

        // 空状态
        if root.item-count == 0: VerticalLayout {
            alignment: center;
            height: 200px;
            spacing: 6px;

            Text {
                text: "暂无剪贴板内容";
                font-size: 13px;
                color: text-2;
                horizontal-alignment: center;
            }

            Text {
                text: "复制文本后将自动显示在这里";
                font-size: 11px;
                color: text-3;
                horizontal-alignment: center;
            }
        }

        // 剪贴板列表
        ListView {
            for entry in root.items: Rectangle {
                height: 52px;
                border-radius: 10px;
                background: item-ta.pressed ? surface-press : item-ta.has-hover ? surface-hover : surface;
                border-width: 1px;
                border-color: divider;

                item-ta := TouchArea {
                    width: parent.width - 32px;
                    height: parent.height;
                    clicked => {
                        if (root.click-pending && root.last-clicked-id == entry.id) {
                            root.click-pending = false;
                            root.last-clicked-id = -1;
                            root.paste-item(entry.id);
                        } else {
                            root.last-clicked-id = entry.id;
                            root.click-pending = true;
                        }
                    }
                }

                HorizontalLayout {
                    padding: 6px;
                    padding-left: 10px;
                    spacing: 8px;

                    // 类型图标 - 文本 (使用 iconfont)
                    if entry.content-type == "text": Rectangle {
                        width: 34px;
                        height: 34px;
                        border-radius: 9px;
                        background: accent-soft;

                        Text {
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            text: "\u{e60e}";
                            font-family: "iconfont";
                            font-size: 18px;
                            color: accent;
                        }
                    }

                    // 类型图标 - 图片 (使用 iconfont)
                    if entry.content-type == "image": Rectangle {
                        width: 34px;
                        height: 34px;
                        border-radius: 9px;
                        background: accent-soft;

                        Text {
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            text: "\u{e626}";
                            font-family: "iconfont";
                            font-size: 18px;
                            color: accent;
                        }
                    }

                    VerticalLayout {
                        spacing: 2px;

                        Text {
                            text: entry.preview;
                            font-size: 12px;
                            color: text-1;
                            overflow: elide;
                            horizontal-alignment: left;
                            vertical-alignment: center;
                        }

                        Text {
                            text: entry.time-label;
                            font-size: 10px;
                            color: text-3;
                            horizontal-alignment: left;
                            vertical-alignment: center;
                        }
                    }

                    // 复制按钮
                    Rectangle {
                        width: 28px;
                        height: 28px;
                        border-radius: 7px;
                        background: copy-ta.has-hover ? btn-hover : transparent;

                        copy-ta := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => {
                                root.click-pending = false;
                                root.last-clicked-id = -1;
                                root.copy-item(entry.id);
                            }
                        }

                        Text {
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            text: "C";
                            font-size: 11px;
                            font-weight: 700;
                            color: copy-ta.has-hover ? accent : text-3;
                        }
                    }
                }
            }
        }
    }
}
