export component SettingsPanel inherits Rectangle {
    // ========== 输入属性 ==========
    in property <bool> dark-mode: false;
    in property <bool> auto-start: false;
    in property <string> db-path: "";
    in property <string> settings-error: "";

    // ========== 内部状态 ==========
    in-out property <int> active-tab: 0;

    // ========== 回调 ==========
    callback back();
    callback toggle-auto-start();
    callback pick-db-path();

    // ========== 主题色板 ==========
    property <color> surface:       dark-mode ? #181a26 : #ffffff;
    property <color> text-1:        dark-mode ? #e6e9f2 : #1a1c2e;
    property <color> text-2:        dark-mode ? #8a8ea8 : #7c809a;
    property <color> text-3:        dark-mode ? #555874 : #b4b9ca;
    property <color> accent:        dark-mode ? #8b8eff : #5f5ff0;
    property <color> accent-soft:   dark-mode ? #222440 : #eeeefd;
    property <color> divider:       dark-mode ? #262840 : #e6e8f0;
    property <color> btn-hover:     dark-mode ? #262840 : #f0f1f8;
    property <color> danger:        #ff5f57;

    background: transparent;

    // ========== 顶部导航栏 ==========
    HorizontalLayout {
        y: 8px;
        height: 36px;
        x: 8px;
        width: parent.width - 16px;
        spacing: 8px;
        alignment: start;

        Rectangle {
            width: 28px;
            height: 28px;
            border-radius: 7px;
            background: back-ta.has-hover ? btn-hover : transparent;
            y: (parent.height - self.height) / 2;

            back-ta := TouchArea {
                width: parent.width;
                height: parent.height;
                clicked => { root.back(); }
            }

            Text {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                text: "<";
                font-size: 12px;
                font-weight: 700;
                color: text-2;
            }
        }

        Text {
            text: "设置";
            font-size: 14px;
            font-weight: 700;
            color: text-1;
            vertical-alignment: center;
        }
    }

    // ========== 选项卡栏 ==========
    HorizontalLayout {
        y: 52px;
        height: 36px;
        x: 8px;
        width: parent.width - 16px;
        spacing: 0px;

        Rectangle {
            width: 50%;
            height: 100%;

            HorizontalLayout {
                alignment: center;

                Text {
                    text: "通用设置";
                    font-size: 12px;
                    font-weight: root.active-tab == 0 ? 700 : 400;
                    color: root.active-tab == 0 ? accent : text-2;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                }
            }

            TouchArea {
                width: parent.width;
                height: parent.height;
                clicked => { root.active-tab = 0; }
            }

            Rectangle {
                height: 2px;
                background: root.active-tab == 0 ? accent : transparent;
                y: parent.height - self.height;
                width: parent.width;
                animate background { duration: 200ms; easing: ease-out; }
            }
        }

        Rectangle {
            width: 50%;
            height: 100%;

            HorizontalLayout {
                alignment: center;

                Text {
                    text: "数据设置";
                    font-size: 12px;
                    font-weight: root.active-tab == 1 ? 700 : 400;
                    color: root.active-tab == 1 ? accent : text-2;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                }
            }

            TouchArea {
                width: parent.width;
                height: parent.height;
                clicked => { root.active-tab = 1; }
            }

            Rectangle {
                height: 2px;
                background: root.active-tab == 1 ? accent : transparent;
                y: parent.height - self.height;
                width: parent.width;
                animate background { duration: 200ms; easing: ease-out; }
            }
        }
    }

    // ========== 通用设置 ==========
    Rectangle {
        y: 96px;
        height: 66px;
        x: 8px;
        width: parent.width - 16px;
        border-radius: 10px;
        background: surface;
        border-width: 1px;
        border-color: divider;
        visible: root.active-tab == 0;
        opacity: root.active-tab == 0 ? 1 : 0;
        animate opacity { duration: 150ms; easing: ease-out; }

        HorizontalLayout {
            width: parent.width;
            height: parent.height;
            padding: 14px;
            alignment: space-between;

            VerticalLayout {
                spacing: 2px;
                alignment: center;

                Text {
                    text: "开机自启动";
                    font-size: 12px;
                    font-weight: 600;
                    color: text-1;
                }

                Text {
                    text: "系统启动时自动运行 Clippi";
                    font-size: 10px;
                    color: text-3;
                }
            }

            Rectangle {
                width: 40px;
                height: 22px;
                border-radius: 11px;
                background: root.auto-start ? accent : divider;
                animate background { duration: 200ms; easing: ease-out; }
                y: (parent.height - self.height) / 2;

                Rectangle {
                    width: 18px;
                    height: 18px;
                    border-radius: 9px;
                    background: #ffffff;
                    x: root.auto-start ? parent.width - self.width - 2px : 2px;
                    animate x { duration: 200ms; easing: ease-out; }
                    y: (parent.height - self.height) / 2;
                }

                toggle-ta := TouchArea {
                    width: parent.width;
                    height: parent.height;
                    clicked => { root.toggle-auto-start(); }
                }
            }
        }
    }

    // ========== 数据设置 ==========
    Rectangle {
        y: 96px;
        height: 76px;
        x: 8px;
        width: parent.width - 16px;
        border-radius: 10px;
        background: surface;
        border-width: 1px;
        border-color: divider;
        visible: root.active-tab == 1;
        opacity: root.active-tab == 1 ? 1 : 0;
        animate opacity { duration: 150ms; easing: ease-out; }

        VerticalLayout {
            width: parent.width;
            height: parent.height;
            padding: 14px;
            spacing: 6px;

            Text {
                text: "数据库路径";
                font-size: 12px;
                font-weight: 600;
                color: text-1;
            }

            HorizontalLayout {
                spacing: 6px;

                Rectangle {
                    height: 28px;
                    border-radius: 7px;
                    background: dark-mode ? #12131c : #f2f3f8;

                    Text {
                        text: root.db-path;
                        font-size: 10px;
                        color: text-2;
                        vertical-alignment: center;
                        x: 10px;
                        overflow: elide;
                        width: parent.width - 20px;
                    }
                }

                Rectangle {
                    height: 28px;
                    width: 52px;
                    border-radius: 7px;
                    background: change-ta.has-hover ? accent-soft : accent;

                    change-ta := TouchArea {
                        width: parent.width;
                        height: parent.height;
                        clicked => { root.pick-db-path(); }
                    }

                    Text {
                        text: "更改";
                        font-size: 11px;
                        font-weight: 600;
                        color: change-ta.has-hover ? accent : #ffffff;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }

    // ========== 错误提示 ==========
    if root.settings-error != "": Rectangle {
        y: 180px;
        height: 28px;
        x: 8px;
        width: parent.width - 16px;
        border-radius: 7px;
        background: surface;

        Text {
            text: root.settings-error;
            font-size: 10px;
            color: danger;
            vertical-alignment: center;
            x: 10px;
        }
    }
}
